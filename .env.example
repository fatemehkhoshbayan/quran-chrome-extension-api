# Quran Foundation API (https://api-docs.quran.foundation/request-access)
CLIENT_ID=
CLIENT_SECRET=

# Chrome extension: ID from chrome://extensions (32 chars), secret is your shared secret
EXTENSION_ID=
EXTENSION_SECRET=

# Gemini (set GEMINI_API_KEY in Vercel → Environment Variables for Production)
GEMINI_API_KEY=
# Optional; default is a current stable model (1.5 IDs are retired on the Gemini API)
# GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — optional fallback when Gemini fails or returns no text (https://openrouter.ai/)
OPENROUTER_API_KEY=
# Optional; default is Qwen3 Next 80B free tier (often 429 when upstream is saturated)
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Optional second model if the primary keeps returning 429 (pick any model slug from openrouter.ai/models)
# OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini